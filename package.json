{
  "name": "rekall",
  "version": "1.0.0",
  "description": "Remember where you were - Context recovery for developers",
  "type": "module",
  "bin": {
    "rekall": "./bin/rekall.js"
  },
  "scripts": {
    "build": "tsup src/cli/index.ts --format esm --dts --outDir dist",
    "dev": "tsup src/cli/index.ts --format esm --watch",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "git",
    "copilot",
    "context",
    "productivity",
    "developer-tools"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
